            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"quantity\": 50,\n  \"notes\": \"Carga inicial de stock\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/entries",
              "host": ["{{baseUrl}}"],
              "path": ["api", "entries"]
            }
          }
        }
      ]
