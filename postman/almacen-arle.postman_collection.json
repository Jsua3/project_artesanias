            },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/reports/alerts?threshold=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "reports", "alerts"],
              "query": [
                { "key": "threshold", "value": "10", "description": "Cantidad mínima de stock para generar alerta" }
              ]
            }
          }
        }
      ]
