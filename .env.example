# ============================================================================
# .env.example — Almacén Artesanías
# ============================================================================
# Copiá este archivo a `.env` (mismo directorio) y ajustá lo necesario.
# `docker compose` lo lee automáticamente.
#
#   cp .env.example .env
#
# Los valores por defecto sirven para levantar TODO localmente sin configurar
# nada — excepto Stripe. Sin claves de Stripe, el endpoint
# /api/cliente-ventas/{id}/checkout-session devuelve 503 (modo "deshabilitado"),
# el resto del sistema funciona igual.
#
# En PRODUCCIÓN, cambiá obligatoriamente: DB_PASSWORD, JWT_SECRET, INTERNAL_TOKEN,
# STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET y las STRIPE_*_URL a tu dominio real.
# ============================================================================

# ---------------------- Postgres (compartido entre servicios) ----------------
DB_USER=postgres
DB_PASSWORD=postgres

# ---------------------- JWT e inter-servicios --------------------------------
# 32+ caracteres. En PROD CAMBIAR por un secreto aleatorio real.
JWT_SECRET=32-character-long-secret-key-for-jwt-generation-and-validation
# Token que el gateway inyecta en llamadas internas (header X-Internal-Token).
# En PROD CAMBIAR por un valor aleatorio fuerte.
INTERNAL_TOKEN=my-super-secret-internal-token

# ---------------------- Stripe (Fase 2b) -------------------------------------
# DEJÁ VACÍO para desarrollar sin Stripe (el checkout devolverá 503).
# Para probar pagos en modo test:
#   1. Crear cuenta en https://dashboard.stripe.com
#   2. Dashboard -> Developers -> API keys -> copiar "Secret key" (sk_test_...)
#   3. Instalar Stripe CLI y correr:
#        stripe login
#        stripe listen --forward-to http://localhost:8080/api/stripe/webhook
#      El CLI imprime un `whsec_...` -> ese es STRIPE_WEBHOOK_SECRET.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Moneda del Checkout (cop / usd / eur...). Stripe requiere minúsculas.
STRIPE_CURRENCY=cop

# URLs a las que Stripe redirige tras éxito/cancelación.
# El placeholder {ventaId} lo reemplaza el backend con el UUID de la venta.
STRIPE_SUCCESS_URL=http://localhost/mis-pedidos/{ventaId}?paid=1
STRIPE_CANCEL_URL=http://localhost/checkout?canceled=1

# ---------------------- Catalog (para inventory) -----------------------------
# Normalmente NO tocar: inventory-service habla con catalog dentro de la red
# de Docker via el hostname del servicio.
CATALOG_SERVICE_URL=http://catalog-service:8082
